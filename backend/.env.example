PORT=3000
DB_PATH=./grand_furniture.db

# Webhook secret — if set, /api/events requires X-Webhook-Secret header
WEBHOOK_SECRET=

# ManyChat — leave MODE=mock until a real key is provided
MANYCHAT_MODE=mock
MANYCHAT_API_KEY=
MANYCHAT_FLOW_OFFER=
MANYCHAT_FLOW_BRANCH_INFO=
MANYCHAT_FLOW_REENGAGE=
MANYCHAT_FLOW_IMMEDIATE=

# Meta (Facebook) Conversions API — offline Lead/Purchase events for Custom &
# Lookalike Audiences. Leave empty to disable (events are skipped silently).
# META_PIXEL_ID:        the Pixel / Dataset id from Events Manager
# META_ACCESS_TOKEN:    a System User token with ads_management permission
# META_TEST_EVENT_CODE: optional — fill while testing (Events Manager → Test Events)
META_PIXEL_ID=
META_ACCESS_TOKEN=
META_TEST_EVENT_CODE=
